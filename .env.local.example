# Tuxmapa API Base URL
# Update this to match your production API endpoint
NEXT_PUBLIC_API_URL=https://api.tuxmapa.com.mx/v2

# Map Tile Provider
# Options: thunderforest | openstreetmap
# For Thunderforest, get your API key at https://www.thunderforest.com/
NEXT_PUBLIC_MAP_PROVIDER=thunderforest
NEXT_PUBLIC_THUNDERFOREST_APIKEY=your_api_key_here